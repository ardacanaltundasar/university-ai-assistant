# OpenAI — embedding, cevap üretimi, intent (gerçek değeri .env içine yazın)
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB — vektör indeksi
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=university_agent_collection

# BM25 — anahtar kelime indeksi
BM25_INDEX_PATH=./data/bm25/bm25_index.pkl

# Redis — answer cache ve health
REDIS_URL=redis://redis:6379/0
ENABLE_REDIS_CACHE=true
REDIS_CACHE_TTL_SECONDS=3600

# Backend / frontend (Docker: backend host adı `backend`)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# Yönetim Paneli — basit şifre koruması (JWT/kullanıcı sistemi değil)
ADMIN_DASHBOARD_PASSWORD=change-this-password

# Retrieval debug — true iken /chat yanıtında retrieval_debug
DEBUG_RETRIEVAL=false

# Ingestion — örnek Markdown belgeleri (data/raw/samples)
# true: örnek belgeler indexlenir (hızlı başlangıç)
# false: samples atlanır; İstanbul Medeniyet crawl/PDF kaynakları için tercih edilir
INCLUDE_SAMPLE_DATA=true

# PostgreSQL — chat, agent logları (gerçek değerleri .env içine yazın)
POSTGRES_USER=uni_agent
POSTGRES_PASSWORD=change-this-secret
POSTGRES_DB=uni_agent_db
DATABASE_URL=postgresql+psycopg2://uni_agent:change-this-secret@postgres:5432/uni_agent_db

# Web crawler — yalnızca public kaynaklar (login/OBS yok)
# Örnekler: genel site, öğrenci işleri, BM (staj/MÜDEK/bitirme/mevzuat), fakülte ders programı
UNIVERSITY_CRAWL_URLS=https://www.medeniyet.edu.tr/tr,https://www.medeniyet.edu.tr/tr/duyurular,https://www.medeniyet.edu.tr/documents/file/dosya/2025/06/2025-2026-egitim-ogretim-yili-akademik-takvimi.pdf,https://bilgiislem.medeniyet.edu.tr/tr/sss,https://ogrenciisleri.medeniyet.edu.tr/tr/duyurular/lisans-ogrencilerimizin-ders-secme-kayit-yenileme-islemleri-tip-ve-turizm-fakulteleri-haric,https://ogrenciisleri.medeniyet.edu.tr/tr/harc-odeme-islemleri,https://ogrenciisleri.medeniyet.edu.tr/tr/duyurular/2025-2026-egitim-ogretim-yili-kurumlar-arasi-yatay-gecis-duyurusu,https://muhendislikdogabilimleri.medeniyet.edu.tr/tr/egitim/egitim-planlari,https://ogrenciisleri.medeniyet.edu.tr/tr/dokumanlar/formlar,https://www.medeniyet.edu.tr/tr/iletisim,https://bm.medeniyet.edu.tr/tr/egitim/staj,https://bm.medeniyet.edu.tr/tr/egitim/mudek,https://bm.medeniyet.edu.tr/tr/egitim/bitirme-projesi,https://bm.medeniyet.edu.tr/tr/dokumanlar-ve-mevzuat/mevzuat,https://muhendislikdogabilimleri.medeniyet.edu.tr/tr/egitim/ders-programi
UNIVERSITY_ALLOWED_DOMAINS=medeniyet.edu.tr
CRAWLER_OUTPUT_DIR=./data/raw/web
CRAWLER_PDF_DIR=./data/raw/pdf
CRAWLER_MAX_PAGES=30
CRAWLER_REQUEST_TIMEOUT=10
CRAWLER_DELAY_SECONDS=1
CRAWLER_DOWNLOAD_PDFS=true
