# OpenAI — embedding, grading, validation ve rewrite için gerekli
OPENAI_API_KEY=your_openai_api_key_here

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB — vektör indeksi
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=university_agent_collection

# BM25 — anahtar kelime indeksi
BM25_INDEX_PATH=./data/bm25/bm25_index.pkl

# Redis — answer cache ve health/status
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=true
REDIS_CACHE_TTL_SECONDS=3600

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# Retrieval debug — true iken /chat yanıtında retrieval_debug ve terminal logları
DEBUG_RETRIEVAL=false

# Ingestion — demo Markdown (data/raw/samples)
# true: demo sample belgeleri indexlenir (varsayılan, hızlı GitHub denemesi)
# false: samples atlanır; crawler/PDF ile gerçek okul verisi kullanırken önerilir
INCLUDE_SAMPLE_DATA=true

# PostgreSQL — kalıcı chat, feedback, metadata, agent logları
POSTGRES_USER=uni_agent
POSTGRES_PASSWORD=change-me
POSTGRES_DB=uni_agent_db
# Docker içinde host: postgres | lokal geliştirmede: localhost
DATABASE_URL=postgresql+psycopg2://uni_agent:change-me@postgres:5432/uni_agent_db

# Web crawler — public kaynak toplama (PoC; login/OBS yok)
# Gerçek URL'leri kendi .env dosyanıza kopyalayın; repoda yalnızca örnek değerler bulunur.
UNIVERSITY_CRAWL_URLS=https://www.medeniyet.edu.tr/tr,https://www.medeniyet.edu.tr/tr/duyurular,https://www.medeniyet.edu.tr/documents/file/dosya/2025/06/2025-2026-egitim-ogretim-yili-akademik-takvimi.pdf,https://bilgiislem.medeniyet.edu.tr/tr/sss,https://ogrenciisleri.medeniyet.edu.tr/tr/duyurular/lisans-ogrencilerimizin-ders-secme-kayit-yenileme-islemleri-tip-ve-turizm-fakulteleri-haric,https://ogrenciisleri.medeniyet.edu.tr/tr/harc-odeme-islemleri,https://ogrenciisleri.medeniyet.edu.tr/tr/duyurular/2025-2026-egitim-ogretim-yili-kurumlar-arasi-yatay-gecis-duyurusu,https://muhendislikdogabilimleri.medeniyet.edu.tr/tr/egitim/egitim-planlari,https://ogrenciisleri.medeniyet.edu.tr/tr/dokumanlar/formlar,https://www.medeniyet.edu.tr/tr/iletisim
UNIVERSITY_ALLOWED_DOMAINS=medeniyet.edu.tr
CRAWLER_OUTPUT_DIR=./data/raw/web
CRAWLER_PDF_DIR=./data/raw/pdf
CRAWLER_MAX_PAGES=30
CRAWLER_REQUEST_TIMEOUT=10
CRAWLER_DELAY_SECONDS=1
CRAWLER_DOWNLOAD_PDFS=true
